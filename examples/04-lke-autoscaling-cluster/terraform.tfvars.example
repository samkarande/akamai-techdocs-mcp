# Copy to terraform.tfvars and fill in. Do NOT commit your real tfvars.

# Either set this, or export LINODE_TOKEN in your shell and leave it empty.
linode_token = ""

# Washington, DC.
region = "us-iad-2"

# Check available versions: curl -s -H "Authorization: Bearer $LINODE_TOKEN" https://api.linode.com/v4/lke/versions
k8s_version = "1.35"

label     = "example4-lke"
node_type = "g6-standard-1"

# Desired capacity 2, autoscaling 2..4.
desired_node_count = 2
autoscaler_min     = 2
autoscaler_max     = 4

high_availability = false
